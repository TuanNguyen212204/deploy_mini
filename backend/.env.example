# Copy file này thành `.env` (KHÔNG commit) trong thư mục `backend/`
# Format: KEY=VALUE (giống .properties)
#
# PostgreSQL JDBC URL (tuỳ nhà cung cấp DB):
# - Supabase pooler: jdbc:postgresql://<host>:5432/postgres?sslmode=require
# - Render Postgres: jdbc:postgresql://<host>:5432/<db>?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://<HOST>:5432/<DB>?sslmode=require
SPRING_DATASOURCE_USERNAME=<USERNAME>
SPRING_DATASOURCE_PASSWORD=<PASSWORD>

# Local: 8080 (Render sẽ tự inject PORT)
PORT=8080
