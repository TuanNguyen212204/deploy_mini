# Tùy chọn: nếu không dùng proxy Vite (npm run dev), trỏ thẳng tới backend:
# VITE_API_BASE_URL=http://localhost:8080
#
# Mặc định để trống → frontend gọi /api/... (cùng origin với Vite), proxy chuyển sang :8080
#
# Trending: mặc định dùng mock khớp trang /product/:id. Bật API thật (UUID — chi tiết mock có thể lệch):
# VITE_USE_TRENDING_API=true
