# —— Kết nối Spring Boot (API endpoints: /api/trending-deals, /api/products/search, /api/compare/:id, …) ——
#
# Dev: Để trống VITE_API_BASE_URL → gọi URL tương đối /api/... (Vite proxy sang http://localhost:8080)
# VITE_API_BASE_URL=
#
# Prod: Vercel build không có proxy, nên cần trỏ thẳng backend (CORS phải được bật trên Render).
#       Thay bằng URL thật của Render backend (không có trailing slash):
#       VITE_API_BASE_URL=https://your-render-backend.onrender.com
#
# Trending: dev mặc định gọi API
VITE_USE_TRENDING_API=true

# Supabase (Auth) - bỏ comment và điền thông tin Supabase của bạn:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
